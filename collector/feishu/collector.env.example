# 飞书 AI 用量采集器配置 —— 拷成 ~/.feishu/collector.env 后填写(该文件不进 git)。

# 看板上报地址(服务端 app.py 暴露处)与 Bearer(对应服务端 COLLECTOR_API_TOKENS 之一)
COLLECTOR_URL=https://collector.example.com
COLLECTOR_TOKEN=replace-with-collector-bearer-token

# 工号 → email 域名(externalID=飞连 user_id;email=user_id@域名)
FEISHU_EMAIL_DOMAIN=yourcompany.com

# 你的飞书企业域名(管理后台 host)
FEISHU_HOST=your-tenant.feishu.cn

# 日期预设:近一周/近一月/近三月/近半年/近一年(默认近一月,约覆盖一个计费周期)
FEISHU_PRESET=近一月

# 飞连凭证(选填;有则身份取权威 email/姓名/全部门路径,与看板其它源口径一致)
FEILIAN_ENDPOINT=
FEILIAN_ACCESS_KEY_ID=
FEILIAN_ACCESS_KEY_SECRET=

# 登录态失效告警:飞书自定义机器人 webhook(选填)
LARK_ALERT_WEBHOOK=
