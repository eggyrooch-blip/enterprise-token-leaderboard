# 收集端配置
DATABASE_URL=postgresql://tok:tok@postgres:5432/tokleaderboard
# 客户端上报用的 Bearer token，可逗号分隔发多把（如按部门区分）
COLLECTOR_API_TOKENS=replace-with-a-long-random-token

# ---- LiteLLM 同步 (litellm_sync.py 用) ----
LITELLM_BASE_URL=http://your-litellm:4000
LITELLM_MASTER_KEY=sk-your-litellm-master-key

# ── 订阅名单同步（subscriptions_sync.py + subscriptions-sync.timer 用）──────
# 必填：飞书自建应用 bot 凭证（须有订阅名单表的读取权限）
FEISHU_APP_ID=cli_your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
# LiteLLM 的 user 字段 -> 公司 email 的映射文件(JSON: {"litellm_user_id": "a@b.com"})；
# 若 LiteLLM 里 user 本来就是 email，可留空。
LITELLM_USER_MAP=

# ---- 代码指标：Cursor 同步 (cursor_admin_sync.py 用) ----
CURSOR_API_BASE=https://api.cursor.com
CURSOR_API_KEY=your-cursor-team-admin-api-key
