# deploy/.env.example — 部署凭证模板
# 真实值填入 pipeline/.env（已 gitignore），由 deploy.sh 自动读取并上传到远端。
# 绝不把填好的文件提交到 git。

# 飞连 OpenAPI 凭证（从飞连管理后台 → OpenAPI 应用 → 密钥中获取）
FEILIAN_ENDPOINT=https://mdm.example.com:8443
FEILIAN_ACCESS_KEY_ID=your_access_key_id_here
FEILIAN_ACCESS_KEY_SECRET=your_access_key_secret_here

# collector 鉴权 token（员工 Mac 上报时在 Authorization: Bearer <token> 中使用）
# 多个 token 用逗号分隔，例如：prod_token_abc,fallback_token_xyz
COLLECTOR_API_TOKENS=your_prod_token_here

# ── LiteLLM 网关同步（litellm_collector.py + litellm-sync.timer 用）────────
# 必填：从 ai-gateway-onboard/.env 里拿同一把 master key（只读管理 API）
LITELLM_BASE_URL=https://litellm.example.com
LITELLM_MASTER_KEY=sk-your-litellm-master-key

# ── 订阅名单同步（subscriptions_sync.py + subscriptions-sync.timer 用）──────
# 必填：飞书自建应用 bot 凭证（须有订阅名单表的读取权限）
FEISHU_APP_ID=cli_your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# ── 飞书通讯录同步（feishu_directory_sync.py + feishu-directory-sync.timer 用）──
# 同一套 FEISHU_APP_ID/FEISHU_APP_SECRET；bot 需开启 contact-read 通讯录读取权限，
# 并在飞书后台可见全部需要统计/授权的部门。
# 根部门默认 0；如飞书租户要求指定根部门，可覆盖。
# FEISHU_ROOT_DEPT=0
# 超级管理员/管理员邮箱 allowlist，逗号分隔；sunke@keep.com 代码内固定为超管兜底。
# AUTH_ADMIN_EMAILS=ops@example.com,security@example.com
# 低于业务外包归因覆盖率阈值时默认阻断写库；只有孙可明确接受风险时才设 1。
# ALLOW_LOW_FEISHU_ATTRIBUTION_COVERAGE=0

# ── 飞书 OAuth 登录（AUTH_ENFORCE=1 前必须配置并实测回调）──────────────
# FEISHU_OAUTH_REDIRECT_URI=https://collector.example.com/v1/auth/callback
# AUTH_ENFORCE=0
# AUTH_COOKIE_SECURE=1

# 可选：agent 榜判定依据。默认按 team alias 'agent' 自动解析 team_id；解析不到时回退下面的 id。
# LITELLM_AGENT_TEAM_ALIAS=agent
# LITELLM_AGENT_TEAM_ID=example-team-id
# 可选：lifetime/month 聚合窗口起点（越早覆盖越全，响应越大）
# LITELLM_HISTORY_START=2025-01-01
# 可选：探针/测试 key 别名前缀，命中即从榜单剔除（无真人 owner 的调试噪音）。默认 tmp-，逗号分隔
# LITELLM_PROBE_ALIAS_PREFIXES=tmp-,test-
# 可选：探针/垃圾 key 精确别名（整名相等才剔除，适合短别名/服务号，避免前缀误伤），逗号分隔
# LITELLM_PROBE_ALIASES=some-service-agent,ss,scratch
# 可选：key 归属覆盖表，给无 user_id/created_by 的 key 手工钉 alias→邮箱（src_alias:dst_email 逗号分隔）
# LITELLM_KEY_OWNER_MAP=legacy-admin:ops@example.com
# 可选：身份合并，把分身/外部邮箱归并到规范真人邮箱（src:dst 逗号分隔）。含真实邮箱，勿提交真值
# LITELLM_EMAIL_MERGE_MAP=someone_v@example.com:someone@example.com,foo123@gmail.com:foo@example.com

# 可选覆盖（deploy.sh 已有默认值，通常不需要改）
# PORT=8090
# DEV_DB=/home/it/tokreport/tok.db
